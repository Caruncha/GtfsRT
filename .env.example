# -------------------------------------------------------
# Configuration des flux GTFS-RT
# Copier ce fichier en .env et remplir les valeurs
# -------------------------------------------------------

# URLs des flux (laisser vide pour désactiver le bouton de récupération)
GTFSRT_TRIPUPDATES_URL=
GTFSRT_VEHICLEPOSITIONS_URL=
GTFSRT_GTFS_ZIP_URL=

# --- Authentification (choisir une méthode) ---

# Méthode 1 : Clé API dans un header HTTP
# GTFSRT_API_KEY=ma_cle_api
# GTFSRT_API_KEY_HEADER=apikey        # nom du header (défaut: apikey)

# Méthode 2 : Token Bearer
# GTFSRT_BEARER_TOKEN=mon_token

# Méthode 3 : Authentification HTTP basique
# GTFSRT_USERNAME=utilisateur
# GTFSRT_PASSWORD=mot_de_passe

# Timeout en secondes pour les requêtes HTTP (défaut: 30)
# GTFSRT_TIMEOUT=30
